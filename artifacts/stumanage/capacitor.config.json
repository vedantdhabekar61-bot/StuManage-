{
  "appId": "com.stumanage.app",
  "appName": "StuManage",
  "webDir": "dist/public",
  "android": {
    "buildOptions": {
      "releaseType": "AAB"
    }
  },
  "server": {
    "androidScheme": "https",
    "cleartext": false
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 2000,
      "backgroundColor": "#0ea495",
      "androidSplashResourceName": "splash",
      "showSpinner": false
    }
  }
}
